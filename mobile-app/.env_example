# Mobile App Environment Variables
# Copy this file to .env and fill in your values

# ─── API URL ────────────────────────────────────────────────────────────────
# For Expo Go on a PHYSICAL device, use your machine's local network IP
# (NOT localhost - your phone can't reach your PC's localhost!)
# Run: ipconfig (Windows) or ifconfig (Mac) to find your IP
# Example: http://192.168.1.100:5000/api
EXPO_PUBLIC_API_URL=http://192.168.1.100:5000/api

# For Android Emulator only:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:5000/api

# For iOS Simulator only:
# EXPO_PUBLIC_API_URL=http://localhost:5000/api

# ─── Google Maps ────────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
